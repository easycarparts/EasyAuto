# Copy this file to .env.local and fill in the real values from your Supabase dashboard
# (Settings → API). Never commit .env.local.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-secret-service-role-key

# Cloudinary (optional — for serving/uploading images)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your-unsigned-video-preset
NEXT_PUBLIC_CLOUDINARY_IMAGE_PRESET=easyauto-listings
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Database pooler (only needed for migrations / scripts)
SUPABASE_DB_PASSWORD=
SUPABASE_DB_URL=

# Google Places API (server-only — live review refresh on owner dashboard)
GOOGLE_PLACES_API_KEY=

# Claude API key for AI listing-description enrichment (scripts/enrich-descriptions.mjs)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Resend — server-only transactional email (Supabase auth SMTP is configured in the dashboard)
RESEND_API_KEY=
