# Copy this file to .env.local and fill in the real values from your Supabase dashboard
# (Settings → API). Never commit .env.local.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-secret-service-role-key

# Cloudinary (optional — for serving/uploading images)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your-unsigned-preset
CLOUDINARY_API_KEY=your-api-key          # only for signed/bulk server uploads
CLOUDINARY_API_SECRET=your-api-secret

# Unsigned Cloudinary preset for listing IMAGES (create in Cloudinary dashboard).
NEXT_PUBLIC_CLOUDINARY_IMAGE_PRESET=easyauto-listings
